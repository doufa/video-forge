# ==========================================
# VideoForge 环境变量配置模板
# 复制此文件并重命名为 .env 然后填入真实的值
# ==========================================

# ------------------------------------------
# 编剧模块 (Script Writer) - 推荐使用具有良好指令遵循的大模型
# ------------------------------------------
# 例如硅基流动 (SiliconFlow)、阿里百炼或 OpenAI 官方
SCRIPT_LLM_API_KEY=your_script_writer_api_key
SCRIPT_LLM_BASE_URL=https://api.siliconflow.cn/v1
SCRIPT_LLM_MODEL=deepseek-ai/DeepSeek-V3

# ------------------------------------------
# 视觉/多模态模块 (Phase 3 & QA 模块) - 用于分析视频画面、打标签
# ------------------------------------------
# 后续 Phase 3 会用到类似 Gemini Flash 或 GPT-4o 的视觉大模型
VISION_LLM_API_KEY=your_vision_model_api_key
VISION_LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
VISION_LLM_MODEL=gemini-2.5-flash

# ------------------------------------------
# 语音/其他扩展 API (预留)
# ------------------------------------------
# 例如后续如果接入 ElevenLabs 配音
ELEVENLABS_API_KEY=your_elevenlabs_api_key
